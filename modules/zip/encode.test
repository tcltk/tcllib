test zipfile-encode-encode-3.0 {write a zip file, test the file list} -setup {
    # Cf. the code that generates zipFileFromEncode.zip in the test file header.
    tcltest::makeDirectory foo
    tcltest::makeDirectory foo/a
    tcltest::makeFile {}   foo/a/x
    tcltest::makeFile {Greetings from Earth!}  foo/a/msg.txt
    set comment {This is a zip file created by zipfile::encode for purposes of testing.}
} -cleanup {
    tcltest::removeDirectory foo
    tcltest::removeFile zipFileFromEncode-3-0.zip
    ::newForTest destroy
    unset -nocomplain comment
} -body {
    zipfile::encode ::newForTest
    ::newForTest comment: $comment
    ::newForTest file: bar/b/msg1.txt 0 foo/a/msg.txt
    ::newForTest file: bar/b/x1       0 foo/a/x
    ::newForTest write zipFileFromEncode-3-0.zip
    lsort -dict [zipfile::decode::content zipFileFromEncode-3-0.zip]
    # zipfile::decode::content does not necessarily return files in archive order.
} -result [list {*}{
    bar/b/msg1.txt
    bar/b/x1
}]

test zipfile-encode-encode-3.1 {write a zip file with changed file names, test the file list} -setup {
    tcltest::makeDirectory foo
    tcltest::makeDirectory foo/a
    tcltest::makeFile {}   foo/a/x
    tcltest::makeFile {Greetings from Earth!}  foo/a/msg.txt
    set comment {This is a zip file created by zipfile::encode for purposes of testing.}
} -cleanup {
    tcltest::removeDirectory foo
    tcltest::removeFile zipFileFromEncode-3-1.zip
    ::newForTest destroy
    unset -nocomplain comment
} -body {
    zipfile::encode ::newForTest
    ::newForTest comment: $comment
    ::newForTest file: bar/b/msg1.txt 0 foo/a/msg.txt
    ::newForTest file: bar/b/x1       0 foo/a/x
    ::newForTest write zipFileFromEncode-3-1.zip
    lsort -dict [zipfile::decode::content zipFileFromEncode-3-1.zip]
    # zipfile::decode::content does not necessarily return files in archive order.
} -result [list {*}{
    bar/b/msg1.txt
    bar/b/x1
}]



test zipfile-encode-encode-4.0 {test file is zip} -setup {
} -body {
    zipfile::decode::iszip zipFileFromEncode.zip
} -result 1

test zipfile-encode-encode-4.1 {test file is not zip} -setup {
    tcltest::makeFile {This is a plain text file}  notazipfile.zip
} -cleanup {
    tcltest::removeFile notazipfile.zip
} -body {
    zipfile::decode::iszip notazipfile.zip
} -result 0

test zipfile-encode-encode-4.2 {test file list, method content} -setup {
} -body {
    lsort -dict [zipfile::decode::content zipFileFromEncode.zip]
} -result [list {*}{
    foo/a/msg.txt
    foo/a/x
}]



test zipfile-encode-encode-5.0 {test unzipfile file list} -setup {
} -cleanup {
    tcltest::removeDirectory foo2
    unset -nocomplain pattern res
} -body {
    zipfile::decode::unzipfile zipFileFromEncode.zip foo2
    set res {}
    foreach pattern {
        foo2/*
        foo2/*/*
        foo2/*/*/*
        foo2/*/*/*/*
    } {
        lappend res [glob -nocomplain $pattern]
    }
    set res
} -result {foo2/foo foo2/foo/a {foo2/foo/a/msg.txt foo2/foo/a/x} {}}

test zipfile-encode-encode-5.1 {test unzipfile file types} -setup {
} -cleanup {
    tcltest::removeDirectory foo2
    unset -nocomplain f res
} -body {
    zipfile::decode::unzipfile zipFileFromEncode.zip foo2
    set res {}
    foreach f {
        foo2/foo foo2/foo/a foo2/foo/a/msg.txt foo2/foo/a/x
    } {
        lappend res [file exists $f][file isdirectory $f][file isfile $f]
    }
    set res
} -result {110 110 101 101}

test zipfile-encode-encode-5.2 {test unzipfile file contents} -setup {
} -cleanup {
    tcltest::removeDirectory foo2
    unset -nocomplain f g res
} -body {
    zipfile::decode::unzipfile zipFileFromEncode.zip foo2
    set res {}
    foreach {f g} [list \
        foo2/foo/a/msg.txt $fileContent \
        foo2/foo/a/x       {} \
    ] {
        lappend res [expr {[tcltest::viewFile $f] eq $g}]
    }
    set res
} -result {1 1}



test zipfile-encode-encode-6.0 {test comment} -setup {
} -cleanup {
    unset -nocomplain adict com2
} -body {
    zipfile::decode::open zipFileFromEncode.zip
    set adict [zipfile::decode::archive]
    set com2  [zipfile::decode::comment $adict]
    zipfile::decode::close
    expr {$com2 eq $commentAll}
} -result 1

test zipfile-encode-encode-6.1 {test file list, method files} -setup {
} -cleanup {
    unset -nocomplain adict ls
} -body {
    zipfile::decode::open zipFileFromEncode.zip
    set adict [zipfile::decode::archive]
    set ls [zipfile::decode::files $adict]
    zipfile::decode::close
    lsort -dict $ls
} -result [list {*}{
    foo/a/msg.txt
    foo/a/x
}]

test zipfile-encode-encode-6.2 {test file date, method filetime} -constraints {} -setup {
} -cleanup {
    unset -nocomplain adict date
} -body {
    zipfile::decode::open zipFileFromEncode.zip
    set adict [zipfile::decode::archive]
    set date [zipfile::decode::filetime $adict foo/a/x]
    zipfile::decode::close
    set date
} -result $zipDate

test zipfile-encode-encode-6.3 {test file date, method filetime; zipfile::encode does not preserve datestamps, ticket 1ae6b4775e} -constraints {knownBug} -setup {
} -cleanup {
    unset -nocomplain adict date
} -body {
    zipfile::decode::open zipFileFromEncode.zip
    set adict [zipfile::decode::archive]
    set date [zipfile::decode::filetime $adict foo/a/msg.txt]
    zipfile::decode::close
    set date
} -result $fileDate

test zipfile-encode-encode-6.4 {test file date, method filetime, precalculated zip 1} -constraints {GotZipFile} -setup {
} -cleanup {
    unset -nocomplain adict date
} -body {
    zipfile::decode::open $externalZipFile
    set adict [zipfile::decode::archive]
    set date [zipfile::decode::filetime $adict foo/a/x]
    zipfile::decode::close
    set date
} -result 1772991348

test zipfile-encode-encode-6.5 {test file date, method filetime, precalculated zip 2} -constraints {GotZipFile} -setup {
} -cleanup {
    unset -nocomplain adict date
} -body {
    zipfile::decode::open $externalZipFile
    set adict [zipfile::decode::archive]
    set date [zipfile::decode::filetime $adict foo/a/msg.txt]
    zipfile::decode::close
    set date
} -result 1770022800


# -------------------------------------------------------------------------

tcltest::removeFile zipFileFromEncode.zip
unset -nocomplain fileContent commentAll fileDate zipDate externalZipFile

testsuiteCleanup

