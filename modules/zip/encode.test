# -------------------------------------------------------------------------

source [file join \
	[file dirname [file dirname [file join [pwd] [info script]]]] \
	devtools testutilities.tcl]

testsNeedTcl     8.6
testsNeedTcltest 2

support {
    useLocal decode.tcl zipfile::decode
}
testing {
    useLocal encode.tcl zipfile::encode
}

# Create a zip file zipFileFromEncode.zip for testing.
# Also define variables fileContent, commentAll, fileDate, zipDate,
# externalZipFile for use by tests.

set fileContent {Greetings from Earth!}
tcltest::makeDirectory foo
tcltest::makeDirectory foo/a
tcltest::makeFile {}   foo/a/x
tcltest::makeFile $fileContent  foo/a/msg.txt
set fileDate 1770022800
file mtime foo/a/msg.txt $fileDate
# Resolution of dates in zip files is 2s
set zipDate [expr {([clock seconds] / 2) * 2}]
set commentAll {This is a zip file created by zipfile::encode for purposes of testing.}

zipfile::encode ::newForTest
::newForTest comment: $commentAll
::newForTest file: foo/a/msg.txt 0 foo/a/msg.txt
::newForTest file: foo/a/x       0 foo/a/x
::newForTest write zipFileFromEncode.zip
::newForTest destroy

tcltest::removeDirectory foo

set externalZipFile [file join [file dirname [info script]] zipFileForTests.zip]
tcltest::testConstraint GotZipFile [file exists $externalZipFile]

# -------------------------------------------------------------------------


test zipfile-encode-encode-1.0 {encode, wrong args, not enough} -body {
    zipfile::encode
} -returnCodes error -result {wrong # args: should be "zipfile::encode subcommand ?arg ...?"}

test zipfile-encode-encode-1.1 {encode, %AUTO%} -body {
    set tmp1 [zipfile::encode %AUTO%]
} -cleanup {
    $tmp1 destroy
    unset tmp1
} -result {::encode*} -match glob

test zipfile-encode-encode-1.2 {encode, fully qualified command name} -body {
    zipfile::encode ::someName
} -cleanup {
    ::someName destroy
} -result {::someName}

test zipfile-encode-encode-1.3 {encode, unqualified command name} -body {
    namespace eval ::tmpZipTest {zipfile::encode someName}
} -cleanup {
    ::tmpZipTest::someName destroy
    namespace delete ::tmpZipTest
} -result {::tmpZipTest::someName}

test zipfile-encode-encode-1.4 {encode, %AUTO%, in namespace} -body {
    set tmp1 [namespace eval ::tmpZipTest {zipfile::encode %AUTO%}]
} -cleanup {
    $tmp1 destroy
    namespace delete ::tmpZipTest
    unset tmp1
} -result {::tmpZipTest::encode*} -match glob

test zipfile-encode-encode-1.5 {encode, unqualified command name, in namespace} -body {
    namespace eval ::tmpZipTest {zipfile::encode someName}
} -cleanup {
    ::tmpZipTest::someName destroy
    namespace delete ::tmpZipTest
} -result {::tmpZipTest::someName}

test zipfile-encode-encode-1.6 {encode, qualified command name, in namespace} -body {
    namespace eval ::tmpZipTest {zipfile::encode someNs::someName}
} -cleanup {
    ::tmpZipTest::someNs::someName destroy
    namespace delete ::tmpZipTest
} -result {::tmpZipTest::someNs::someName}



